# Clé API Anthropic — utilisée à partir du Sprint 1 (analyse LLM).
# À déclarer en *repository secret* sous le nom ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=

# Fourni automatiquement par GitHub Actions (secrets.GITHUB_TOKEN).
# À ne renseigner que pour des essais locaux contre la vraie API GitHub.
GITHUB_TOKEN=
