# Fournisseur LLM : "claude" (défaut) ou "gemini".
LLM_PROVIDER=claude

# Clé API Anthropic — requise si LLM_PROVIDER=claude.
# À déclarer en *repository secret* sous le nom ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=

# Clé API Google AI Studio — requise si LLM_PROVIDER=gemini.
# À déclarer en *repository secret* sous le nom GEMINI_API_KEY.
GEMINI_API_KEY=

# (Optionnel) surcharge du modèle par fournisseur.
# CLAUDE_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-3.5-flash

# Fourni automatiquement par GitHub Actions (secrets.GITHUB_TOKEN).
# À ne renseigner que pour des essais locaux contre la vraie API GitHub.
GITHUB_TOKEN=
